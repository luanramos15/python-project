# Flask Configuration
FLASK_APP=src/app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Database Configuration
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=seu_password_seguro
MYSQL_DATABASE=email_classification

# SQLAlchemy
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:seu_password_seguro@db:3306/email_classification

# Hugging Face Models
HUGGINGFACE_MODEL_CLASSIFICATION=facebook/bart-large-mnli

# Response model (runs on HF Inference API, not locally)
HUGGINGFACE_MODEL_RESPONSE=Qwen/Qwen2.5-72B-Instruct

# Free API token — get yours at https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# NLP Configuration
LANGUAGE=pt  # Português

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=true
